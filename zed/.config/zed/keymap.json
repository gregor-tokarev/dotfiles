      "cmd-d": [
        "task::Spawn",
        { "lazygit": "open_lazydocker", "reveal_target": "center" }
      ],
      "cmd-o cmd-r": "projects::OpenRecent"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      // "j k": ["workspace::SendKeystrokes", "escape"]
      "cmd-g": [
        "task::Spawn",
        { "lazygit": "open_lazygit", "reveal_target": "center" }
      ],
      "cmd-d": [
        "task::Spawn",
        { "lazygit": "open_lazydocker", "reveal_target": "center" }
      ]
    }
  }
]
